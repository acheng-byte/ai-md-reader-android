<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 常显：转发 / 分享当前文档 -->
    <item
        android:id="@+id/action_share"
        android:icon="@drawable/ic_share"
        android:title="@string/action_share"
        app:showAsAction="always" />

    <!-- 常显：目录 -->
    <item
        android:id="@+id/action_toc"
        android:icon="@drawable/ic_toc"
        android:title="@string/action_toc"
        app:showAsAction="always" />

    <!-- 常显：源码 / 预览切换 -->
    <item
        android:id="@+id/action_toggle"
        android:icon="@drawable/ic_code"
        android:title="@string/action_view_code"
        app:showAsAction="always" />

    <!-- 常显：收藏 / 取消收藏切换（图标随状态在代码中切换为实心/空心星） -->
    <item
        android:id="@+id/action_favorite"
        android:icon="@drawable/ic_star_border"
        android:title="@string/action_favorite"
        app:showAsAction="always" />

    <!-- 以下进入「更多菜单」(⋮) -->
    <item
        android:id="@+id/action_open"
        android:icon="@drawable/ic_open"
        android:title="@string/action_open"
        app:showAsAction="never" />

    <item
        android:id="@+id/action_favorites"
        android:icon="@drawable/ic_star"
        android:title="@string/action_favorites"
        app:showAsAction="never" />

    <item
        android:id="@+id/action_history"
        android:icon="@drawable/ic_history"
        android:title="@string/action_history"
        app:showAsAction="never" />
</menu>

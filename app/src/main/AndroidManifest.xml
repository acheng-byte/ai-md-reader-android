<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 用于加载 Markdown 中引用的远程图片/链接（可选；纯本地阅读不会联网） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 用于直接下载并安装更新 APK -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.MdReader">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode"
            android:label="@string/app_name">

            <!-- 启动器入口 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- A. 按 MIME 匹配：content:// 与 file:// 均适用（覆盖微信等通过 content:// 分享的场景）。
                 .md 无标准 MIME，微信常以 application/octet-stream 传递，故一并登记。 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/markdown" />
                <data android:mimeType="text/x-markdown" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="application/markdown" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>

            <!-- B. 按扩展名匹配（无 mimeType）：覆盖文件管理器以 file:// 且不带类型打开 .md 的情况。
                 pathPattern 通配存在“首匹配即止”限制，故为多级文件名补多条规则。 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.md" />
                <data android:pathPattern=".*\\..*\\.md" />
                <data android:pathPattern=".*\\..*\\..*\\.md" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.md" />
                <data android:pathPattern=".*\\.markdown" />
                <data android:pathPattern=".*\\..*\\.markdown" />
                <data android:pathPattern=".*\\..*\\..*\\.markdown" />
            </intent-filter>

            <!-- C. 按扩展名匹配（mimeType=*/*）：覆盖带任意类型且路径含 .md 的 file:// 打开。 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.md" />
                <data android:pathPattern=".*\\..*\\.md" />
                <data android:pathPattern=".*\\..*\\..*\\.md" />
                <data android:pathPattern=".*\\.markdown" />
                <data android:pathPattern=".*\\..*\\.markdown" />
            </intent-filter>

            <!-- D. DOCX / DOC 匹配 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
                <data android:mimeType="application/msword" />
            </intent-filter>

            <!-- E. DOCX/DOC/TXT 按扩展名匹配 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.docx" />
                <data android:pathPattern=".*\\..*\\.docx" />
                <data android:pathPattern=".*\\.doc" />
                <data android:pathPattern=".*\\..*\\.doc" />
                <data android:pathPattern=".*\\.txt" />
                <data android:pathPattern=".*\\..*\\.txt" />
            </intent-filter>

            <!-- F. PDF MIME 匹配 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
            </intent-filter>

            <!-- G. PDF 按扩展名匹配 -->
            <intent-filter
                android:label="@string/open_with_label"
                tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.pdf" />
                <data android:pathPattern=".*\\..*\\.pdf" />
                <data android:pathPattern=".*\\..*\\..*\\.pdf" />
            </intent-filter>
        </activity>

        <!-- 用于把当前 md 文档以文件形式分享/转发给微信等应用 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
